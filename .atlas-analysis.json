  "keyFeatures": [
    "Event creation and management with image upload and geolocation via Nominatim",
    "Ticket purchasing with capacity tracking and attendee counting",
    "Role-based access control (admin and user roles)",
    "REST API for events, categories, locations, and statuses",
    "PDF report generation for events and tickets using DomPDF",
    "Admin dashboard for managing users, categories, and event statuses",
    "Explore page with filterable event listings",
    "Soft deletes for events and tickets",
    "Laravel Sanctum API authentication support"
  ],
  "publicApiSurface": [
    "GET /api/event — List all events",
    "GET /api/event/{id} — Get a single event",
    "POST /api/event — Create an event",
    "PUT /api/event/{id} — Update an event",
    "DELETE /api/event/{id} — Delete an event",
    "GET /api/category — List all categories",
    "GET /api/category/{id} — Get a single category",
    "POST /api/category — Create a category",
    "PUT /api/category/{id} — Update a category",
    "DELETE /api/category/{id} — Delete a category",
    "GET /api/locations — List all locations",
    "GET /api/statuses — List all statuses"
  ]
